# LIMINAL — environment variables template
#
# Copy this file to `.env.local` and fill in your own values.
# `.env.local` is gitignored automatically (*.local pattern).
#
# Vite client-side rule: only variables prefixed with `VITE_` are
# exposed to browser code via `import.meta.env`.

# === REQUIRED ===

# QuickNode Solana Mainnet HTTP Provider URL.
# Get yours at: https://dashboard.quicknode.com → Endpoints → [your endpoint]
# Format: https://your-name.solana-mainnet.quiknode.pro/your-token/
VITE_QUICKNODE_RPC_URL=

# === OPTIONAL ===

# DFlow endorsement server (defaults to https://pond.dflow.net if unset).
# VITE_DFLOW_API_URL=https://pond.dflow.net
